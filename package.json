{
  "name": "taste-canvas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"vite\" \"tsx watch --env-file-if-exists=.env.local server/dev.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx watch --env-file-if-exists=.env.local server/dev.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:api",
    "test:api": "vitest run",
    "test:smoke": "playwright test",
    "vercel-build": "npm run build",
    "dev:smoke": "concurrently -n web,api -c blue,magenta \"TASTE_API_PORT=3102 vite --host 127.0.0.1 --port 5174\" \"PORT=3102 tsx --env-file-if-exists=.env.local server/dev.ts\""
  },
  "engines": {
    "node": ">=22.12 <26",
    "npm": ">=10"
  },
  "browserslist": [
    "Chrome >= 120",
    "Edge >= 120",
    "Firefox >= 121",
    "Safari >= 17"
  ],
  "dependencies": {
    "@sparticuz/chromium": "^143.0.4",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/blob": "^2.3.3",
    "framer-motion": "^12.38.0",
    "puppeteer-core": "^24.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.1",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.6"
  }
}

{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/upload.ts": {
      "maxDuration": 30
    },
    "api/screenshot.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/tweet.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

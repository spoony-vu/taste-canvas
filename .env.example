# taste-canvas environment template
# Copy this file to .env.local for local dev, and set the same values
# in your Vercel project settings (Project → Settings → Environment Variables)
# for production.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Vercel Blob storage token
# ─────────────────────────────────────────────────────────────────────────────
# Get this from: Vercel dashboard → your project → Storage → connect Blob store
# Local: vercel env pull .env.local will populate this for you.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED in production — API auth key for write endpoints
# ─────────────────────────────────────────────────────────────────────────────
# Generate any random string (e.g. `openssl rand -hex 32`).
# Used by:
#  - The browser frontend via same-origin (auto)
#  - The browser extension (paste the same value into the extension's settings)
#  - Any external script (Authorization: Bearer <key>)
# If unset locally, write endpoints are open (convenient for dev).
TASTE_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Optional — public canonical URL (for og:url, og:image)
# ─────────────────────────────────────────────────────────────────────────────
# Set this to your deployed origin so social previews render correctly.
# Example: https://your-taste-canvas.vercel.app
VITE_PUBLIC_URL=""
